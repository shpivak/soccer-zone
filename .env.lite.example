# ─── Soccer Lite — local development env vars ────────────────────────────────
# Copy to .env.local and fill in real values.
# These are the lite-specific vars; the shared Supabase connection vars
# (VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY) are the same as soccer-zone.

# Enable lite mode (path-based routing, per-league auth, tournament-only)
VITE_LITE_MODE=true

# Override the three dataset schemas to point at the soccerlite_* schemas
VITE_SUPABASE_DEV_SCHEMA=soccerlite_dev
VITE_SUPABASE_TEST_SCHEMA=soccerlite_test
VITE_SUPABASE_PROD_SCHEMA=soccerlite_prod

# Super password required to create a new league (REQUIRED — no code fallback)
VITE_LITE_SUPER_PASSWORD=change-me-before-deploying

# Shared connection — same Supabase project as soccer-zone
# VITE_STORAGE_PROVIDER=supabase
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# Dataset to use locally (default: dev)
# VITE_DEFAULT_DATASET=dev
# VITE_ENABLE_PROD_DATASET=false
# VITE_ALLOW_PROD_WRITES=false

# Per-league admin passwords used by seed script and e2e tests (REQUIRED for those commands)
LITE_DEV_LEAGUE_PASSWORD=change-me
LITE_TEST_LEAGUE_PASSWORD=change-me
LITE_PROD_LEAGUE_PASSWORD=change-me

# Script-side (not bundled — used by scripts/lite/seed-lite-leagues.mjs)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_DEV_SCHEMA=soccerlite_dev
# SUPABASE_TEST_SCHEMA=soccerlite_test
# SUPABASE_PROD_SCHEMA=soccerlite_prod
