{
  "name": "soccer-zone",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:e2e": "VITE_DEFAULT_DATASET=test playwright test",
    "test:e2e:all": "npm run test:e2e && npm run lite:test:e2e",
    "db:backup:dev": "node scripts/dev-db/backup-dev-db.mjs",
    "db:seed:dev": "SUPABASE_TARGET_DATASET=dev node scripts/migrate-mock-data-to-supabase.mjs",
    "db:reset:dev": "ALLOW_DEV_DB_RESET=true SUPABASE_TARGET_DATASET=dev SEED_AFTER_RESET=false node scripts/reset-supabase-dataset.mjs",
    "db:seed:test": "SUPABASE_TARGET_DATASET=test node scripts/migrate-mock-data-to-supabase.mjs",
    "db:reset:test": "SUPABASE_TARGET_DATASET=test node scripts/reset-supabase-dataset.mjs",
    "lite:dev": "VITE_LITE_MODE=true VITE_SUPABASE_DEV_SCHEMA=soccerlite_dev VITE_SUPABASE_TEST_SCHEMA=soccerlite_test VITE_SUPABASE_PROD_SCHEMA=soccerlite_prod vite --port 5174",
    "lite:build": "VITE_LITE_MODE=true VITE_SUPABASE_DEV_SCHEMA=soccerlite_dev VITE_SUPABASE_TEST_SCHEMA=soccerlite_test VITE_SUPABASE_PROD_SCHEMA=soccerlite_prod vite build",
    "lite:test:e2e": "VITE_LITE_MODE=true VITE_DEFAULT_DATASET=test playwright test --config=playwright.lite.config.js",
    "lite:db:seed:dev": "SUPABASE_DEV_SCHEMA=soccerlite_dev ALLOW_DEV_DB_RESET=true SUPABASE_TARGET_DATASET=dev node scripts/lite/seed-lite-leagues.mjs dev",
    "lite:db:seed:test": "SUPABASE_TEST_SCHEMA=soccerlite_test SUPABASE_TARGET_DATASET=test node scripts/lite/seed-lite-leagues.mjs test",
    "lite:db:seed:prod": "SUPABASE_PROD_SCHEMA=soccerlite_prod ALLOW_PROD_WRITES=true SUPABASE_TARGET_DATASET=prod node scripts/lite/seed-lite-leagues.mjs prod",
    "lite:db:reset:test": "SUPABASE_TEST_SCHEMA=soccerlite_test SUPABASE_TARGET_DATASET=test node scripts/reset-supabase-dataset.mjs"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "vite": "^7.3.1"
  }
}
